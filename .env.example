# 本地开发可参考这些值，但网页默认要求用户在侧边栏填写 API Key。
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-turbo

# 默认禁止 HTTP 与内网模型地址。仅在完全可信的本地开发环境中开启。
ALLOW_INSECURE_LLM_HTTP=false

# 可选：限制服务端允许访问的模型域名，逗号分隔。
# LLM_ALLOWED_HOSTS=dashscope.aliyuncs.com,api.deepseek.com
